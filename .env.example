# Demo mode: cache_first | live | mock_only
# - mock_only: zero external calls, uses fixtures
# - cache_first: real on first run for a query, cached after
# - live: always real
DEMO_MODE=mock_only

# Anthropic (required for query parsing + mocked transcripts)
ANTHROPIC_API_KEY=

# Browser-Use Cloud v3 (required for cache_first and live)
BROWSER_USE_API_KEY=

# AgentPhone (required for cache_first and live)
AGENTPHONE_API_KEY=
AGENTPHONE_WEBHOOK_SECRET=
PUBLIC_WEBHOOK_URL=
# Phone number AgentPhone will actually dial. Friend's phone for demo.
REAL_DEMO_NUMBER=

# Sponge (required for real EASY BOOKING charge)
SPONGE_API_KEY=
