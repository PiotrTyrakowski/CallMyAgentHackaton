# Demo mode: cache_first | live | mock_only
# - mock_only: zero external calls, uses fixtures
# - cache_first: real on first run for a query, cached after
# - live: always real
DEMO_MODE=mock_only

# Anthropic (required for query parsing + mocked transcripts)
ANTHROPIC_API_KEY=

# Browser-Use Cloud v3 (required for cache_first and live)
BROWSER_USE_API_KEY=

# AgentPhone — hosted mode (build the agent on their platform, we just dial)
AGENTPHONE_API_KEY=
# ID of the hosted agent you configured on agentphone.dev (with the negotiation
# system prompt + phone number attached)
AGENTPHONE_AGENT_ID=
# Endpoint to trigger an outbound call. Update if AgentPhone's path differs.
AGENTPHONE_CALL_URL=https://api.agentphone.dev/v1/calls
# Phone number AgentPhone will actually dial. Friend's phone for demo.
REAL_DEMO_NUMBER=

# Sponge (required for real EASY BOOKING charge)
SPONGE_API_KEY=
