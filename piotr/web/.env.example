# Copy to .env.local and fill in the keys you want to wire up.
#
# Each provider auto-detects: if the corresponding API key(s) are present, the
# live adapter runs; otherwise the in-process dev adapter runs. Drop in a key
# → goes live. Comment it out → back to dev.

# --- Browser-Use (offer discovery) -------------------------------------------
# BROWSERUSE_API_KEY=          # from cloud.browser-use.com
# BROWSERUSE_ENDPOINT=         # optional override, defaults to api.browser-use.com

# --- AgentPhone (outbound negotiation calls) ---------------------------------
# AGENTPHONE_API_KEY=          # from cloud.agentphone.ai
# AGENTPHONE_AGENT_ID=         # the agent you configured in the dashboard
# AGENTPHONE_PHONE_MAP=        # {"offer-id":"+14155550101", ...}
# AGENTPHONE_TEST_NUMBER=      # fallback for offer ids not in the map
# Live calling needs BOTH the API key and the agent id.

# --- Sponge (per-transaction virtual cards for the booking authorization) ----
# SPONGE_API_KEY=              # sponge_live_… from wallet.paysponge.com
# SPONGE_API_URL=              # default https://api.wallet.paysponge.com
# SPONGE_DASHBOARD_URL=        # default https://wallet.paysponge.com
# SPONGE_CHAIN=tempo           # tempo | base
# Caps the per-card hold while running against the hackathon wallet ($5 USDC).
# Bump to the full negotiated stay total in production.
# SPONGE_MAX_AUTHORIZATION_USD=4.50

# --- Supermemory (persistent user-preference + geo memory) -------------------
# SUPERMEMORY_API_KEY=         # without this, an in-process fallback runs
