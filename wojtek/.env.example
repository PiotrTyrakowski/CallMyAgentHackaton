# Copy to .env.local and fill in the keys you actually want to wire up.
# Each provider defaults to its mock impl. Flip to `real` to use the *.real.ts
# adapter.

# --- mode switches -----------------------------------------------------------
PROVIDERS_BROWSERUSE=mock   # mock | real
PROVIDERS_AGENTPHONE=mock   # mock | real
PROVIDERS_PAYMENTS=mock     # mock | real

# --- browseruse --------------------------------------------------------------
# BROWSERUSE_API_KEY=
# BROWSERUSE_ENDPOINT=

# --- AgentPhone --------------------------------------------------------------
# AGENTPHONE_API_KEY=        # from cloud.agentphone.ai
# AGENTPHONE_AGENT_ID=       # the agent you configured in the dashboard
# Used by /api/test-call (side test page at /test-call) and by
# providers/agentphone.real.ts when PROVIDERS_AGENTPHONE=real.

# --- Payments (x402 / mpp) ---------------------------------------------------
# X402_API_KEY=
# X402_RELAY_URL=
# MPP_MERCHANT_ID=
# MPP_SECRET=
