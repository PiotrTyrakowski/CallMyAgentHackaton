# Copy to .env.local and fill in the keys you actually want to wire up.
# Each provider defaults to its mock impl. Flip to `real` to use the *.real.ts
# adapter — but you must implement that adapter first (see providers/*.real.ts).

# --- mode switches -----------------------------------------------------------
PROVIDERS_BROWSERUSE=mock   # mock | real
PROVIDERS_AGENTPHONE=mock   # mock | real
PROVIDERS_MOSS=mock         # mock | real
PROVIDERS_PAYMENTS=mock     # mock | real

# --- browseruse --------------------------------------------------------------
# BROWSERUSE_API_KEY=
# BROWSERUSE_ENDPOINT=
# ANTHROPIC_API_KEY=        # if running the LLM-driven browser locally

# --- AgentPhone --------------------------------------------------------------
# AGENTPHONE_API_KEY=
# AGENTPHONE_WEBHOOK_URL=   # public URL the AgentPhone service will POST to
# Use WEBHOOK mode (not hosted) per YCHack brief — more capabilities + harnesses

# --- Moss --------------------------------------------------------------------
# MOSS_API_KEY=
# MOSS_ENDPOINT=            # or self-hosted

# --- Payments (x402 / mpp) ---------------------------------------------------
# X402_API_KEY=
# X402_RELAY_URL=
# MPP_MERCHANT_ID=
# MPP_SECRET=
